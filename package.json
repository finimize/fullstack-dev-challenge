    "postinstall": "cd client && yarn install"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.0",
    "mocha": "^11.0.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.0"
  }
}
