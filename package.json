{
  "name": "fullstack-dev-challenge",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@4.10.3",
  "dependencies": {
    "express": "^5.1.0"
  },
  "scripts": {
    "start": "concurrently \"yarn server\" \"yarn client\"",
